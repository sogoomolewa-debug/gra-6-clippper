# Environment Variables Template
# Copy this to .env and fill in the missing values

# 1. YouTube Data API v3 Key (for search)
YOUTUBE_API_KEY=

# 2. YouTube OAuth2 JSON (for upload)
# Format: {"client_id": "...", "client_secret": "...", "refresh_token": "...", "token_uri": "..."}
YOUTUBE_OAUTH_JSON=

# 3. Gemini API Key (for clip visual analysis via Gemini 2.5 Flash)
GEMINI_API_KEY=

# 4. Modal TTS Endpoint (Supports comma-separated fallback endpoint pools)
MODAL_TTS_ENDPOINT=https://fynduo--qwen3-tts-generate.modal.run,https://richardmarenco357--qwen3-tts-generate.modal.run

# 5. Reference Text for Voice Clone (Transcription of assets/voice_sample.wav)
REF_TEXT=Disparity between the number of foreign and local patent application
